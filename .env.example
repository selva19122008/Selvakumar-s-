# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Gmail SMTP OTP credentials
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_digit_app_password

# Optional DKIM credentials to prevent spam classification
DKIM_DOMAIN_NAME=yourdomain.com
DKIM_KEY_SELECTOR=default
DKIM_PRIVATE_KEY=your_dkim_private_key_placeholder

