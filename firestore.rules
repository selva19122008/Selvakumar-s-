rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the requesting user's UID matches the authorized administrator's hardcoded UID,
    // matches an authorized list element, or matches the authenticated administrator's email.
    function isAdmin(request) {
      return request.auth != null && (
        request.auth.uid == "ADMIN_FIREBASE_UID_PLACEHOLDER" || 
        request.auth.uid == "Z0p9YnVfM6iiog" || 
        request.auth.uid == "selva_admin_uid_main_phone" || 
        request.auth.token.email == "battlezone.support@gmail.com"
      );
    }

    // Match users collection - read/write is open to enable seamless mobile number lookups,
    // registration fallbacks, and real-time account data coordination on the client side.
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Match joins collection - reader and client writers permitted for real-time join list syncing
    match /joins/{joinId} {
      allow read, write: if true;
    }
    
    // Match tournaments collection - allowed for authenticated users to read, restricted to admin for writes
    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request);
    }
    
    // Match withdrawals collection
    match /withdrawals/{withdrawalId} {
      allow read, write: if true;
    }

    // Match settings (like global_config)
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
